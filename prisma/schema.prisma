generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TripStatus {
  ONGOING
  UPCOMING
  COMPLETED
}

enum ExpenseCategory {
  HOTEL
  TRAVEL
  FOOD
  ACTIVITY
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
}

enum PackingCategory {
  DOCUMENTS
  CLOTHING
  ELECTRONICS
  OTHER
}

model User {
  id             String          @id @default(cuid())
  firstName      String
  lastName       String
  email          String          @unique
  password       String
  phone          String?
  city           String?
  country        String?
  bio            String?
  role           Role            @default(USER)

  trips          Trip[]
  notes          Note[]
  packingItems   PackingItem[]
  expenses       Expense[]
  communityPosts CommunityPost[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Trip {
  id             String          @id @default(cuid())
  userId         String

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  title          String
  description    String?

  status         TripStatus      @default(UPCOMING)

  isPublic       Boolean         @default(false)

  startDate      DateTime
  endDate        DateTime

  totalBudget    Float           @default(0)

  stops          TripStop[]
  expenses       Expense[]
  packingItems   PackingItem[]
  notes          Note[]

  invoice        Invoice?
  sharedTrip     SharedTrip?

  communityPosts CommunityPost[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model TripStop {
  id         String         @id @default(cuid())

  tripId     String

  trip       Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)

  city       String
  country    String

  startDate  DateTime
  endDate    DateTime

  budget     Float          @default(0)

  notes      String?

  position   Int            @default(0)

  activities TripActivity[]

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Activity {
  id             String         @id @default(cuid())

  name           String
  category       String

  description    String?

  location       String?

  cost           Float          @default(0)

  duration       Float          @default(0)

  tripActivities TripActivity[]

  createdAt      DateTime       @default(now())
}

model TripActivity {
  id         String    @id @default(cuid())

  stopId     String
  activityId String

  stop       TripStop  @relation(fields: [stopId], references: [id], onDelete: Cascade)

  activity   Activity  @relation(fields: [activityId], references: [id])

  date       DateTime?

  time       String?

  cost       Float     @default(0)

  notes      String?

  createdAt  DateTime  @default(now())
}

model Expense {
  id          String          @id @default(cuid())

  tripId      String
  userId      String

  trip        Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)

  user        User            @relation(fields: [userId], references: [id])

  category    ExpenseCategory

  description String

  quantity    Float           @default(1)

  unitCost    Float

  amount      Float

  createdAt   DateTime        @default(now())
}

model Invoice {
  id            String        @id @default(cuid())

  tripId        String        @unique

  trip          Trip          @relation(fields: [tripId], references: [id])

  invoiceNumber String        @unique

  generatedDate DateTime      @default(now())

  paymentStatus PaymentStatus @default(PENDING)

  subtotal      Float

  tax           Float

  discount      Float         @default(0)

  grandTotal    Float

  travelers     String[]

  createdAt     DateTime      @default(now())
}

model PackingItem {
  id        String          @id @default(cuid())

  tripId    String
  userId    String

  trip      Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)

  user      User            @relation(fields: [userId], references: [id])

  category  PackingCategory

  itemName  String

  isPacked  Boolean         @default(false)

  createdAt DateTime        @default(now())
}

model Note {
  id        String   @id @default(cuid())

  tripId    String
  userId    String

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  user      User     @relation(fields: [userId], references: [id])

  stopId    String?

  title     String

  content   String

  dayNumber Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityPost {
  id        String   @id @default(cuid())

  userId    String
  tripId    String?

  user      User     @relation(fields: [userId], references: [id])

  trip      Trip?    @relation(fields: [tripId], references: [id])

  content   String

  likes     Int      @default(0)

  createdAt DateTime @default(now())
}

model SharedTrip {
  id        String   @id @default(cuid())

  tripId    String   @unique

  trip      Trip     @relation(fields: [tripId], references: [id])

  slug      String   @unique

  createdAt DateTime @default(now())
}
